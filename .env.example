# Vesicle — environment. Copy to .env and fill in the blanks. .env is gitignored.
# Loaded automatically by src/env.ts (Node's built-in process.loadEnvFile).

# --- StromaDB engine (the graph Vesicle ingests into) -------------------------------------------
STROMA_URL=http://127.0.0.1:7687
# Preferred: a bearer token (start stroma-serve with the same --api-token). Else the admin login below.
STROMA_API_TOKEN=
STROMA_ADMIN_USER=admin
STROMA_ADMIN_PASSWORD=password

# --- Vesicle app login (the authoring UI) -------------------------------------------------------
VESICLE_USER=admin
VESICLE_PASSWORD=password
# 1 = disable the login gate (local dev only).
VESICLE_NO_AUTH=0
PORT=5178

# --- LLM (mapping proposer / extractor) ---------------------------------------------------------
# With a key → Anthropic API; without → the local `claude` CLI (developer fallback, not shipped).
ANTHROPIC_API_KEY=
VESICLE_MODEL=claude-opus-4-8

# --- Backlog OAuth app --------------------------------------------------------------------------
# Register under the space's Integrations → Developer settings. The redirect URI MUST be exactly:
#   <PUBLIC_URL>/api/backlog/oauth/callback
BACKLOG_CLIENT_ID=
BACKLOG_CLIENT_SECRET=
# This server's public base — used for the OAuth redirect and (if you use webhooks) the hook URL.
# Local dev: http://localhost:5178  (localhost is fine for the OAuth callback; it's browser-side).
PUBLIC_URL=http://localhost:5178

# --- Backlog streaming --------------------------------------------------------------------------
# Optional shared secret the webhook requires as ?secret=… (webhook path only; polling doesn't use it).
BACKLOG_WEBHOOK_SECRET=
# Poll interval in ms for the pull-based ingest (default 15000).
BACKLOG_POLL_MS=15000

# --- Conformance review -------------------------------------------------------------------------
# Name recorded as the reviewer on human-confirmed write-back facts.
VESICLE_REVIEWER=
