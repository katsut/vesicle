{
  "label": "HR / projects (sample)",
  "schema": "CREATE TABLE departments (\n    id   INT PRIMARY KEY,\n    name TEXT NOT NULL\n);\n\nCREATE TABLE employees (\n    id            INT PRIMARY KEY,\n    name          TEXT NOT NULL,\n    department_id INT REFERENCES departments(id),\n    manager_id    INT REFERENCES employees(id)   -- self-ref: org hierarchy\n);\n\nCREATE TABLE projects (\n    id       INT PRIMARY KEY,\n    name     TEXT NOT NULL,\n    priority TEXT,        -- low | medium | high\n    status   TEXT         -- planned | active | done\n);\n\nCREATE TABLE assignments (\n    id          INT PRIMARY KEY,\n    employee_id INT REFERENCES employees(id),\n    project_id  INT REFERENCES projects(id),\n    role        TEXT,       -- edge property\n    allocation  INT,        -- edge property (percent)\n    start_date  DATE,       -- valid-time start\n    end_date    DATE        -- valid-time end (NULL = current)\n);\n\nCREATE TABLE skills (\n    id   INT PRIMARY KEY,\n    name TEXT NOT NULL\n);\n\nCREATE TABLE employee_skills (\n    employee_id INT REFERENCES employees(id),\n    skill_id    INT REFERENCES skills(id),\n    level       INT,        -- 1..5 (edge property)\n    PRIMARY KEY (employee_id, skill_id)\n);\n\nCREATE TABLE project_skills (\n    project_id INT REFERENCES projects(id),\n    skill_id   INT REFERENCES skills(id),\n    PRIMARY KEY (project_id, skill_id)\n);\n\nCREATE TABLE documents (\n    id                 INT PRIMARY KEY,\n    title              TEXT NOT NULL,\n    body               TEXT,\n    author_employee_id INT REFERENCES employees(id)\n);",
